{
  "settings": {
    "index": { "number_of_shards": 1, "number_of_replicas": 0 },
    "analysis": {
      "filter": {
        "english_stop": { "type": "stop", "stopwords": "_english_" },
        "product_synonyms": {
          "type": "synonym",
          "synonyms": ["hp, handphone, smartphone, phone", "laptop, notebook", "tv, television"]
        },
        "autocomplete_edge": { "type": "edge_ngram", "min_gram": 2, "max_gram": 20 }
      },
      "analyzer": {
        "product_index": { "tokenizer": "standard", "filter": ["lowercase", "asciifolding", "product_synonyms", "english_stop"] },
        "autocomplete_index": { "tokenizer": "standard", "filter": ["lowercase", "asciifolding", "autocomplete_edge"] },
        "product_search": { "tokenizer": "standard", "filter": ["lowercase", "asciifolding", "product_synonyms", "english_stop"] }
      }
    }
  },
  "mappings": {
    "properties": {
      "id": { "type": "long" },
      "sku": { "type": "keyword" },
      "name": {
        "type": "text", "analyzer": "product_index", "search_analyzer": "product_search",
        "fields": {
          "keyword": { "type": "keyword" },
          "auto": { "type": "text", "analyzer": "autocomplete_index", "search_analyzer": "product_search" },
          "sayt": { "type": "search_as_you_type" },
          "suggest": { "type": "completion" }
        }
      },
      "description": { "type": "text", "analyzer": "product_index", "search_analyzer": "product_search" },
      "brand": { "type": "keyword", "fields": { "text": { "type": "text" } } },
      "category": { "type": "keyword", "fields": { "text": { "type": "text", "analyzer": "product_index" } } },
      "price": { "type": "scaled_float", "scaling_factor": 100 },
      "stock": { "type": "integer" },
      "rating": { "type": "half_float" },
      "tags": { "type": "keyword" },
      "attributes": {
        "type": "nested",
        "properties": {
          "name": { "type": "keyword" },
          "value": { "type": "keyword", "fields": { "text": { "type": "text" } } }
        }
      },
      "created_at": { "type": "date" },
      "updated_at": { "type": "date" }
    }
  }
}
