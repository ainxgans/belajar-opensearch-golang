# PostgreSQL
POSTGRES_USER=catalog
POSTGRES_PASSWORD=catalog
POSTGRES_DB=catalog
DATABASE_URL=postgres://catalog:catalog@postgres:5432/catalog?sslmode=disable

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=products

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=catalog.public.products
KAFKA_GROUP=indexer

# API
API_ADDR=:8080
ENABLE_GENERATOR=true
